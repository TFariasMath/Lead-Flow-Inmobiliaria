# Configuración SMTP Real para pruebas de entrega
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Tu correo de prueba (ej: mi-cuenta@gmail.com)
EMAIL_HOST_USER=
# Tu contraseña de aplicación (NO la contraseña normal de Google)
EMAIL_HOST_PASSWORD=

# El remitente que aparecerá en el correo
DEFAULT_FROM_EMAIL=Lead Flow Lab <tu-correo@gmail.com>
