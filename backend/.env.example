# Lead Flow - Backend Configuration Template
# ==========================================
# Renombrar este archivo a '.env' y completar los valores.

# Configuración de Base de Datos
DB_NAME=leadflow
DB_USER=leadflow_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# Mapbox (Necesario para mapas en Brochures)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=tu_token_de_mapbox_aqui

# Django Security (Cambiar en producción)
DJANGO_SECRET_KEY=django-insecure-change-this-for-production
DJANGO_DEBUG=True
